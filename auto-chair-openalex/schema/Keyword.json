{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Keyword",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "cited_by_count": {
      "type": "integer"
    },
    "works_count": {
      "type": "integer"
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "updated_date": {
      "type": "string",
      "format": "date-time"
    }
  }
}
