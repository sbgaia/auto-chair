{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "abbreviated_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "alternate_titles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "apc_prices": {
      "type": "array",
      "items": {
        "$ref": "./ArticleProcessingCharge.json"
      }
    },
    "apc_usd": {
      "type": [
        "integer",
        "null"
      ]
    },
    "cited_by_count": {
      "type": "integer"
    },
    "country_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "counts_by_year": {
      "type": "array",
      "items": {
        "$ref": "./CountsByYear.json"
      }
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "display_name": {
      "type": "string"
    },
    "homepage_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "host_organization": {
      "type": [
        "string",
        "null"
      ]
    },
    "host_organization_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "host_organization_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openalex": {
          "type": "string"
        },
        "issn_l": {
          "type": [
            "string",
            "null"
          ]
        },
        "issn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mag": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "wikidata": {
          "type": [
            "string",
            "null"
          ]
        },
        "fatcat": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "is_in_doaj": {
      "type": "boolean"
    },
    "is_oa": {
      "type": "boolean"
    },
    "is_core": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "issn": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issn_l": {
      "type": [
        "string",
        "null"
      ]
    },
    "societies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "ror": {
            "type": [
              "string",
              "null"
            ]
          },
          "display_name": {
            "type": "string"
          },
          "country_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "lineage": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary_stats": {
      "$ref": "./SummaryStats.json"
    },
    "type": {
      "type": "string"
    },
    "updated_date": {
      "type": "string",
      "format": "date-time"
    },
    "works_api_url": {
      "type": "string",
      "format": "uri"
    },
    "works_count": {
      "type": "integer"
    },
    "x_concepts": {
      "type": "array",
      "items": {
        "$ref": "./Concept.json"
      }
    }
  }
}
