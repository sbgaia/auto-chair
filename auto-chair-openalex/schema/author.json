{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Author",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "affiliations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "institution": {
            "$ref": "./dehydrated_institution.json"
          },
          "years": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      }
    },
    "cited_by_count": {
      "type": "integer"
    },
    "counts_by_year": {
      "type": "array",
      "items": {
        "$ref": "./counts_by_year.json"
      }
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "display_name": {
      "type": "string"
    },
    "display_name_alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "id": {
      "type": "string"
    },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openalex": {
          "type": "string"
        },
        "orcid": {
          "type": [
            "string",
            "null"
          ]
        },
        "scopus": {
          "type": [
            "string",
            "null"
          ]
        },
        "twitter": {
          "type": [
            "string",
            "null"
          ]
        },
        "wikipedia": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "last_known_institutions": {
      "type": "array",
      "items": {
        "$ref": "./dehydrated_institution.json"
      }
    },
    "orcid": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary_stats": {
      "$ref": "./summary_stats.json"
    },
    "updated_date": {
      "type": "string",
      "format": "date-time"
    },
    "works_api_url": {
      "type": "string",
      "format": "uri"
    },
    "works_count": {
      "type": "integer"
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "./topic.json"
      }
    },
    "topic_share": {
      "type": "array",
      "items": {
        "$ref": "./topic.json"
      }
    },
    "x_concepts": {
      "type": "array",
      "items": {
        "$ref": "./concept.json"
      }
    }
  }
}
