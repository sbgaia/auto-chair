{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Location",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "is_oa": {
      "type": "boolean"
    },
    "landing_page_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "pdf_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "source": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "./dehydrated_source.json"
        }
      ]
    },
    "license": {
      "type": [
        "string",
        "null"
      ]
    },
    "license_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "is_accepted": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "is_published": {
      "type": [
        "boolean",
        "null"
      ]
    }
  }
}
