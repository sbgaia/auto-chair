{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Institution",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "cited_by_count": {
      "type": "integer"
    },
    "country_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "counts_by_year": {
      "type": "array",
      "items": {
        "$ref": "./CountsByYear.json"
      }
    },
    "created_date": {
      "type": "string",
      "format": "date"
    },
    "display_name": {
      "type": "string"
    },
    "display_name_acronyms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "display_name_alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "geo": {
      "$ref": "./Geo.json"
    },
    "homepage_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openalex": {
          "type": "string"
        },
        "ror": {
          "type": [
            "string",
            "null"
          ]
        },
        "grid": {
          "type": [
            "string",
            "null"
          ]
        },
        "wikipedia": {
          "type": [
            "string",
            "null"
          ]
        },
        "wikidata": {
          "type": [
            "string",
            "null"
          ]
        },
        "mag": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        }
      }
    },
    "image_thumbnail_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "image_url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "international": {
      "type": "object",
      "additionalProperties": true
    },
    "is_super_system": {
      "type": "boolean"
    },
    "lineage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repositories": {
      "type": "array",
      "items": {
        "$ref": "./DehydratedSource.json"
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "$ref": "./OrganizationRole.json"
      }
    },
    "associated_institutions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "ror": {
            "type": [
              "string",
              "null"
            ]
          },
          "display_name": {
            "type": "string"
          },
          "country_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "relationship": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "ror": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary_stats": {
      "$ref": "./SummaryStats.json"
    },
    "type": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_date": {
      "type": "string",
      "format": "date-time"
    },
    "works_api_url": {
      "type": "string",
      "format": "uri"
    },
    "works_count": {
      "type": "integer"
    },
    "x_concepts": {
      "type": "array",
      "items": {
        "$ref": "./Concept.json"
      }
    }
  }
}
