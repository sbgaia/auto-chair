{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Publisher",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "alternate_titles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "country_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hierarchy_level": {
      "type": "integer"
    },
    "parent_publisher": {
      "type": [
        "string",
        "null"
      ]
    },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openalex": {
          "type": "string"
        },
        "ror": {
          "type": [
            "string",
            "null"
          ]
        },
        "wikidata": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "sources_api_url": {
      "type": "string",
      "format": "uri"
    },
    "counts_by_year": {
      "type": "array",
      "items": {
        "$ref": "./CountsByYear.json"
      }
    },
    "cited_by_count": {
      "type": "integer"
    },
    "works_count": {
      "type": "integer"
    },
    "updated_date": {
      "type": "string",
      "format": "date-time"
    }
  }
}
